{
  "name": "loomle",
  "version": "0.7.0-rc.2",
  "loomle": {
    "protocolVersion": 2
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "sal",
    "interfaces",
    "client"
  ],
  "scripts": {
    "generate:version": "node packaging/tools/product-version.mjs generate",
    "check:version": "node packaging/tools/product-version.mjs check",
    "build": "npm run check:version && npm run build --workspace @loomle/client",
    "build:executable": "node packaging/client/build.mjs",
    "test:executable": "node packaging/client/test.mjs",
    "assemble:fab": "node packaging/fab/assemble.mjs",
    "test:fab": "node --test packaging/fab/assemble.test.mjs",
    "test:release": "node --test packaging/release/validate-promotion.test.mjs",
    "test:ue-runner": "node --test tests/runner/ue-test-runner.test.mjs",
    "test:packaged-smoke-unit": "npm run build --workspace @loomle/client && node --test tests/integration/packaged-mcp-smoke.test.mjs tests/integration/packaged-runtime-lifecycle.test.mjs",
    "test:ue-automation": "node tests/runner/ue-test-runner.mjs --profile automation",
    "test:packaged-e2e": "node tests/runner/ue-test-runner.mjs --profile packaged_e2e",
    "test": "npm run check:version && node --test packaging/tools/product-version.test.mjs packaging/tools/pe-machine.test.mjs packaging/client/runtime-cache.test.mjs && npm run test:fab && npm run test:release && npm run test:ue-runner && npm run test:packaged-smoke-unit && npm run test --workspace @loomle/sal && npm run test --workspace @loomle/interfaces && npm run test --workspace @loomle/client"
  },
  "devDependencies": {
    "postject": "1.0.0-alpha.6"
  }
}
