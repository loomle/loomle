{
  "tool": "graph.mutate",
  "graphType": "pcg",
  "ops": [
    {
      "op": "addNode.byClass",
      "clientRef": "create_points",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGCreatePointsSettings"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "sample_ratio",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGSelectPointsSettings"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "tag_sampled",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGAddTagSettings"
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "create_points",
          "pin": "Out"
        },
        "to": {
          "nodeRef": "sample_ratio",
          "pin": "In"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "sample_ratio",
          "pin": "Out"
        },
        "to": {
          "nodeRef": "tag_sampled",
          "pin": "In"
        }
      }
    },
    {
      "op": "setPinDefault",
      "args": {
        "target": {
          "nodeRef": "sample_ratio",
          "pin": "Ratio"
        },
        "value": 0.1
      }
    },
    {
      "op": "setPinDefault",
      "args": {
        "target": {
          "nodeRef": "tag_sampled",
          "pin": "TagsToAdd"
        },
        "value": "Gameplay.Sampled"
      }
    },
    {
      "op": "layoutGraph",
      "args": {
        "scope": "touched"
      }
    }
  ]
}
