      "args": {
        "nodeClassPath": "/Script/BlueprintGraph.K2Node_IfThenElse"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "true_print",
      "args": {
        "nodeClassPath": "/Script/BlueprintGraph.K2Node_CallFunction",
        "functionClassPath": "/Script/Engine.KismetSystemLibrary",
        "functionName": "PrintString"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "false_print",
      "args": {
