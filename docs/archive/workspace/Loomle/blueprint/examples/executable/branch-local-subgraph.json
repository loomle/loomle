        "functionName": "PrintString"
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "branch_main",
          "pinName": "Then"
        },
        "to": {
          "nodeRef": "true_print",
          "pinName": "execute"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "branch_main",
          "pinName": "Else"
        },
        "to": {
          "nodeRef": "false_print",
