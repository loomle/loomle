        },
        "value": "Executable local true branch"
      }
    },
    {
      "op": "setPinDefault",
      "args": {
        "target": {
          "nodeRef": "false_print",
          "pinName": "InString"
        },
        "value": "Executable local false branch"
      }
    },
    {
