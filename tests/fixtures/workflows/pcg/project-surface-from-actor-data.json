{
  "tool": "pcg_graph_edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGDataFromActorSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGDataFromActorSettings"
        }
      },
      "alias": "source_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGDataFromActorSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGDataFromActorSettings"
        }
      },
      "alias": "projection_target"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGProjectionSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGProjectionSettings"
        }
      },
      "alias": "project_surface"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_projected"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "source_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "project_surface"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "projection_target"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "project_surface"
        },
        "pin": "Projection Target"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "project_surface"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "tag_projected"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_projected"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.Projected"
    }
  ]
}
