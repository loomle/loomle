{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGStaticMeshSpawnerSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGStaticMeshSpawnerSettings"
        }
      },
      "alias": "static_mesh_spawner"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "static_mesh_spawner"
        },
        "pin": "In"
      }
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGDensityFilterSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGDensityFilterSettings"
        }
      },
      "alias": "density_filter"
    },
    {
      "kind": "disconnect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "static_mesh_spawner"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "density_filter"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "density_filter"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "static_mesh_spawner"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "density_filter"
        },
        "pin": "LowerBound"
      },
      "value": 0.2
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "density_filter"
        },
        "pin": "UpperBound"
      },
      "value": 0.8
    }
  ]
}
