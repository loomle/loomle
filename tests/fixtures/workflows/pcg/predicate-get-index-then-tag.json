{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAttributeGetFromIndexSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAttributeGetFromIndexSettings"
        }
      },
      "alias": "get_index"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_indexed"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "get_index"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "get_index"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "tag_indexed"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "get_index"
        },
        "pin": "Index"
      },
      "value": 2
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_indexed"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.Predicate"
    }
  ]
}
