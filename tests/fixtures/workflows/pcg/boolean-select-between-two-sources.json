{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points_a"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points_b"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGBooleanSelectSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGBooleanSelectSettings"
        }
      },
      "alias": "select_node"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_selected"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points_a"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "select_node"
        },
        "pin": "Input A"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points_b"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "select_node"
        },
        "pin": "Input B"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "select_node"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "tag_selected"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "select_node"
        },
        "pin": "bUseInputB"
      },
      "value": true
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_selected"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.Selected"
    }
  ]
}
