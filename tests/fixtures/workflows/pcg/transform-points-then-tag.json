{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGTransformPointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGTransformPointsSettings"
        }
      },
      "alias": "transform_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_transformed"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "transform_points"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "transform_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "tag_transformed"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "transform_points"
        },
        "pin": "bAbsoluteRotation"
      },
      "value": true
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_transformed"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.Transformed"
    }
  ]
}
