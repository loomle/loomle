{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGDataFromActorSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGDataFromActorSettings"
        }
      },
      "alias": "actor_data"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGFilterByTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGFilterByTagSettings"
        }
      },
      "alias": "filter_by_tag"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_matched_branch"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "actor_data"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "filter_by_tag"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "filter_by_tag"
        },
        "pin": "InsideFilter"
      },
      "to": {
        "node": {
          "alias": "tag_matched_branch"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "filter_by_tag"
        },
        "pin": "SelectedTags"
      },
      "value": "Gameplay.Spawnable"
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_matched_branch"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.Routed"
    }
  ]
}
