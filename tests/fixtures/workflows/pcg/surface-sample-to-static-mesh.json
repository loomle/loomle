{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGDataFromActorSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGDataFromActorSettings"
        }
      },
      "alias": "actor_surface"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGSurfaceSamplerSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGSurfaceSamplerSettings"
        }
      },
      "alias": "surface_sampler"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGStaticMeshSpawnerSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGStaticMeshSpawnerSettings"
        }
      },
      "alias": "static_mesh_spawner"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "actor_surface"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "surface_sampler"
        },
        "pin": "Surface"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "surface_sampler"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "static_mesh_spawner"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "surface_sampler"
        },
        "pin": "PointsPerSquaredMeter"
      },
      "value": 0.2
    }
  ]
}
