{
  "tool": "pcg_graph_edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGSubgraphSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGSubgraphSettings"
        }
      },
      "alias": "subgraph_node"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGGetSubgraphDepthSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGGetSubgraphDepthSettings"
        }
      },
      "alias": "depth_node"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg_palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_depth"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "subgraph_node"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "subgraph_node"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "tag_depth"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "depth_node"
        },
        "pin": "DistanceRelativeToUpstreamGraph"
      },
      "value": 2
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_depth"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.StructDepth"
    }
  ]
}
