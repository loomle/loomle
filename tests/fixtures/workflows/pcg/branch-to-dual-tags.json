{
  "tool": "pcg.graph.edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGCreatePointsSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGCreatePointsSettings"
        }
      },
      "alias": "create_points"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGBranchSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGBranchSettings"
        }
      },
      "alias": "branch_node"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_output_a"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "pcg.palette:/Script/PCG.PCGAddTagSettings",
        "kind": "native",
        "payload": {
          "settingsClass": "/Script/PCG.PCGAddTagSettings"
        }
      },
      "alias": "tag_output_b"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "create_points"
        },
        "pin": "Out"
      },
      "to": {
        "node": {
          "alias": "branch_node"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "branch_node"
        },
        "pin": "Output A"
      },
      "to": {
        "node": {
          "alias": "tag_output_a"
        },
        "pin": "In"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "branch_node"
        },
        "pin": "Output B"
      },
      "to": {
        "node": {
          "alias": "tag_output_b"
        },
        "pin": "In"
      }
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "branch_node"
        },
        "pin": "bOutputToB"
      },
      "value": true
    },
    {
      "kind": "setPinDefault",
      "target": {
        "node": {
          "alias": "tag_output_b"
        },
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.BranchB"
    }
  ]
}
