{
  "tool": "pcg.mutate",
  "ops": [
    {
      "op": "addNode.byClass",
      "clientRef": "create_points",
      "nodeClassPath": "/Script/PCG.PCGCreatePointsSettings"
    },
    {
      "op": "addNode.byClass",
      "clientRef": "branch_node",
      "nodeClassPath": "/Script/PCG.PCGBranchSettings"
    },
    {
      "op": "addNode.byClass",
      "clientRef": "tag_output_a",
      "nodeClassPath": "/Script/PCG.PCGAddTagSettings"
    },
    {
      "op": "addNode.byClass",
      "clientRef": "tag_output_b",
      "nodeClassPath": "/Script/PCG.PCGAddTagSettings"
    },
    {
      "op": "connectPins",
      "from": {
        "nodeRef": "create_points",
        "pin": "Out"
      },
      "to": {
        "nodeRef": "branch_node",
        "pin": "In"
      }
    },
    {
      "op": "connectPins",
      "from": {
        "nodeRef": "branch_node",
        "pin": "Output A"
      },
      "to": {
        "nodeRef": "tag_output_a",
        "pin": "In"
      }
    },
    {
      "op": "connectPins",
      "from": {
        "nodeRef": "branch_node",
        "pin": "Output B"
      },
      "to": {
        "nodeRef": "tag_output_b",
        "pin": "In"
      }
    },
    {
      "op": "setPinDefault",
      "target": {
        "nodeRef": "branch_node",
        "pin": "bOutputToB"
      },
      "value": true
    },
    {
      "op": "setPinDefault",
      "target": {
        "nodeRef": "tag_output_b",
        "pin": "TagsToAdd"
      },
      "value": "Gameplay.BranchB"
    },
    {
      "op": "layoutGraph",
      "scope": "touched"
    }
  ]
}
