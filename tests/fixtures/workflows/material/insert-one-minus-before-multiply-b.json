{
  "tool": "material_graph_edit",
  "commands": [
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "material_palette:/Script/Engine.MaterialExpressionTextureSampleParameter2D",
        "kind": "expression",
        "payload": {
          "nodeClassPath": "/Script/Engine.MaterialExpressionTextureSampleParameter2D"
        }
      },
      "alias": "albedo_tex"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "material_palette:/Script/Engine.MaterialExpressionScalarParameter",
        "kind": "expression",
        "payload": {
          "nodeClassPath": "/Script/Engine.MaterialExpressionScalarParameter"
        }
      },
      "alias": "tint_scalar"
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "material_palette:/Script/Engine.MaterialExpressionMultiply",
        "kind": "expression",
        "payload": {
          "nodeClassPath": "/Script/Engine.MaterialExpressionMultiply"
        }
      },
      "alias": "multiply_tint"
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "albedo_tex"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "alias": "multiply_tint"
        },
        "pin": "A"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "tint_scalar"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "alias": "multiply_tint"
        },
        "pin": "B"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "multiply_tint"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "id": "__material_root__"
        },
        "pin": "Base Color"
      }
    },
    {
      "kind": "addFromPalette",
      "entry": {
        "id": "material_palette:/Script/Engine.MaterialExpressionOneMinus",
        "kind": "expression",
        "payload": {
          "nodeClassPath": "/Script/Engine.MaterialExpressionOneMinus"
        }
      },
      "alias": "invert_tint"
    },
    {
      "kind": "disconnect",
      "from": {
        "node": {
          "alias": "tint_scalar"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "alias": "multiply_tint"
        },
        "pin": "B"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "tint_scalar"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "alias": "invert_tint"
        },
        "pin": "Input"
      }
    },
    {
      "kind": "connect",
      "from": {
        "node": {
          "alias": "invert_tint"
        },
        "pin": "Result"
      },
      "to": {
        "node": {
          "alias": "multiply_tint"
        },
        "pin": "B"
      }
    }
  ]
}
