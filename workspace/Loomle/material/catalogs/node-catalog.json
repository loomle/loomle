  "source": "LOOMLE workspace references",
  "summary": {
    "purpose": "Static catalog of common Material graph nodes that LOOMLE agents are expected to use directly with primitive graph.mutate operations.",
    "notes": [
      "This is a curated inventory, not a full Material expression universe.",
      "The material root sink is represented separately in specialNodes.",
      "Use GUIDE.md for workflow, SEMANTICS.md for behavior, and examples/ for concrete mutate payloads."
    ]
  },
