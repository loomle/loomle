{
  "tool": "graph.mutate",
  "graphType": "pcg",
  "ops": [
    {
      "op": "addNode.byClass",
      "clientRef": "create_points",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGCreatePointsSettings"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "filter_by_tag",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGFilterByTagSettings"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "matched_branch",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGAddTagSettings"
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "unmatched_branch",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGAddTagSettings"
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "create_points",
          "pin": "Out"
        },
        "to": {
          "nodeRef": "filter_by_tag",
          "pin": "In"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "filter_by_tag",
          "pin": "InsideFilter"
        },
        "to": {
          "nodeRef": "matched_branch",
          "pin": "In"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "filter_by_tag",
          "pin": "OutsideFilter"
        },
        "to": {
          "nodeRef": "unmatched_branch",
          "pin": "In"
        }
      }
    },
    {
      "op": "addNode.byClass",
      "clientRef": "sample_inside_branch",
      "args": {
        "nodeClassPath": "/Script/PCG.PCGSelectPointsSettings"
      }
    },
    {
      "op": "disconnectPins",
      "args": {
        "from": {
          "nodeRef": "filter_by_tag",
          "pin": "InsideFilter"
        },
        "to": {
          "nodeRef": "matched_branch",
          "pin": "In"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "filter_by_tag",
          "pin": "InsideFilter"
        },
        "to": {
          "nodeRef": "sample_inside_branch",
          "pin": "In"
        }
      }
    },
    {
      "op": "connectPins",
      "args": {
        "from": {
          "nodeRef": "sample_inside_branch",
          "pin": "Out"
        },
        "to": {
          "nodeRef": "matched_branch",
          "pin": "In"
        }
      }
    },
    {
      "op": "setPinDefault",
      "args": {
        "target": {
          "nodeRef": "sample_inside_branch",
          "pin": "Ratio"
        },
        "value": 0.2
      }
    },
    {
      "op": "layoutGraph",
      "args": {
        "scope": "touched"
      }
    }
  ]
}
