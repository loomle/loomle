bp = blueprint(asset: "/Game/Doors/BP_Door.BP_Door")
eventGraph = graph(asset: bp, name: "EventGraph")
query eventGraph
nodes "Print"
where type = "/Script/BlueprintGraph.K2Node_CallFunction"
page limit 10

---

eventGraph = graph(id: "graph-guid")
print = node(graph: eventGraph, id: "N3", type: "/Script/BlueprintGraph.K2Node_CallFunction", FunctionReference: "PrintString")
