{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loomle.dev/schema/sal-object.schema.json",
  "title": "SAL Normalized Object Schema",
  "description": "Normalized SAL contract for parsing, executors, RPC, ordered Object Text, and diagnostics.",
  "anyOf": [
    { "$ref": "#/$defs/SalObject" },
    { "$ref": "#/$defs/ObjectResult" }
  ],
  "$defs": {
    "Name": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": { "const": "name" },
        "name": { "type": "string", "pattern": "^(?!(?:true|false|null)$)[A-Za-z_][A-Za-z0-9_]*$" }
      }
    },
    "LocalRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": { "const": "local" },
        "name": { "type": "string", "pattern": "^(?!(?:true|false|null)$)[A-Za-z_][A-Za-z0-9_]*$" }
      }
    },
    "StableRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "pattern": "^(?!(?:true|false|null)$)[A-Za-z_][A-Za-z0-9_]*$" },
        "id": { "type": "string", "minLength": 1, "pattern": "^[^\\s.]+$" }
      }
    },
    "MemberRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "object", "path"],
      "properties": {
        "kind": { "const": "member" },
        "object": {
          "oneOf": [
            { "$ref": "#/$defs/LocalRef" },
            { "$ref": "#/$defs/StableRef" }
          ]
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
        }
      }
    },
    "Ref": {
      "oneOf": [
        { "$ref": "#/$defs/LocalRef" },
        { "$ref": "#/$defs/StableRef" },
        { "$ref": "#/$defs/MemberRef" }
      ]
    },
    "Call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "callee", "args"],
      "properties": {
        "kind": { "const": "call" },
        "callee": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
        "args": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
          "additionalProperties": { "$ref": "#/$defs/Expr" }
        }
      }
    },
    "InlineObject": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/Expr" },
      "not": {
        "anyOf": [
          {
            "required": ["kind", "id"]
          },
          {
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["name", "local", "member", "call"] }
            }
          }
        ]
      }
    },
    "Expr": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        { "$ref": "#/$defs/Name" },
        { "$ref": "#/$defs/Ref" },
        { "$ref": "#/$defs/Call" },
        { "type": "array", "items": { "$ref": "#/$defs/Expr" } },
        { "$ref": "#/$defs/InlineObject" }
      ]
    },
    "BindingMemberRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "object", "path"],
      "properties": {
        "kind": { "const": "member" },
        "object": { "$ref": "#/$defs/LocalRef" },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
        }
      }
    },
    "BindingTarget": {
      "oneOf": [
        { "$ref": "#/$defs/LocalRef" },
        { "$ref": "#/$defs/BindingMemberRef" }
      ]
    },
    "Binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "value"],
      "properties": {
        "target": { "$ref": "#/$defs/BindingTarget" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "Edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/Ref" },
        "to": { "$ref": "#/$defs/Ref" }
      }
    },
    "Comment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text"],
      "properties": {
        "kind": { "const": "comment" },
        "text": {
          "oneOf": [
            { "const": "###" },
            {
              "type": "string",
              "minLength": 1,
              "not": { "pattern": "(^|\\r?\\n)[ \\t]*###[ \\t]*(\\r?\\n|$)" }
            }
          ]
        }
      }
    },
    "Statement": {
      "oneOf": [
        { "$ref": "#/$defs/Binding" },
        { "$ref": "#/$defs/Edge" },
        { "$ref": "#/$defs/Comment" }
      ]
    },
    "ObjectText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statements"],
      "properties": {
        "statements": {
          "type": "array",
          "items": { "$ref": "#/$defs/Statement" }
        }
      }
    },
    "Target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias", "value"],
      "properties": {
        "alias": { "type": "string", "pattern": "^(?!(?:true|false|null)$)[A-Za-z_][A-Za-z0-9_]*$" },
        "value": {
          "oneOf": [
            { "$ref": "#/$defs/Call" },
            { "$ref": "#/$defs/Name" }
          ]
        }
      }
    },
    "FieldPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
        }
      }
    },
    "EqCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "field", "value"],
      "properties": {
        "kind": { "const": "eq" },
        "field": { "$ref": "#/$defs/FieldPath" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "NeCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "field", "value"],
      "properties": {
        "kind": { "const": "ne" },
        "field": { "$ref": "#/$defs/FieldPath" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "ContainsCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "field", "value"],
      "properties": {
        "kind": { "const": "contains" },
        "field": { "$ref": "#/$defs/FieldPath" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "CompareCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "op", "field", "value"],
      "properties": {
        "kind": { "const": "compare" },
        "op": { "enum": ["gt", "gte", "lt", "lte"] },
        "field": { "$ref": "#/$defs/FieldPath" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "NotCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "condition"],
      "properties": {
        "kind": { "const": "not" },
        "condition": { "$ref": "#/$defs/Condition" }
      }
    },
    "AndCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "conditions"],
      "properties": {
        "kind": { "const": "and" },
        "conditions": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/Condition" }
        }
      }
    },
    "OrCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "conditions"],
      "properties": {
        "kind": { "const": "or" },
        "conditions": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/Condition" }
        }
      }
    },
    "Condition": {
      "oneOf": [
        { "$ref": "#/$defs/EqCondition" },
        { "$ref": "#/$defs/NeCondition" },
        { "$ref": "#/$defs/ContainsCondition" },
        { "$ref": "#/$defs/CompareCondition" },
        { "$ref": "#/$defs/NotCondition" },
        { "$ref": "#/$defs/AndCondition" },
        { "$ref": "#/$defs/OrCondition" }
      ]
    },
    "OrderBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "direction"],
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*$" },
        "direction": { "enum": ["asc", "desc"] }
      }
    },
    "Page": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "after": { "type": "string", "minLength": 1 }
      }
    },
    "SummaryOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": { "kind": { "const": "summary" } }
    },
    "CollectionOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "assets",
            "variables",
            "dispatchers",
            "graphs",
            "components",
            "nodes",
            "properties",
            "functions",
            "defaults",
            "widgets"
          ]
        },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "NamedOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "enum": [
            "variable",
            "dispatcher",
            "graph",
            "component",
            "property",
            "function",
            "default",
            "widget"
          ]
        },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "IdOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "enum": [
            "blueprint",
            "variable",
            "dispatcher",
            "graph",
            "component",
            "node",
            "pin",
            "widget",
            "palette"
          ]
        },
        "id": { "type": "string", "minLength": 1, "pattern": "^\\S+$" }
      }
    },
    "TreeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "tree" },
        "root": { "$ref": "#/$defs/StableRef" },
        "depth": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "ContextOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "context" },
        "target": { "$ref": "#/$defs/StableRef" },
        "depth": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "FlowOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "direction", "target"],
      "properties": {
        "kind": { "enum": ["exec_flow", "data_flow"] },
        "direction": { "enum": ["from", "to"] },
        "target": { "$ref": "#/$defs/StableRef" },
        "depth": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "PalettePinContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "pin"],
      "properties": {
        "direction": { "enum": ["from", "to"] },
        "pin": { "$ref": "#/$defs/StableRef" }
      }
    },
    "PaletteEntriesOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "palette_entries" },
        "text": { "type": "string", "minLength": 1 },
        "pinContext": { "$ref": "#/$defs/PalettePinContext" }
      }
    },
    "QueryOperation": {
      "oneOf": [
        { "$ref": "#/$defs/SummaryOperation" },
        { "$ref": "#/$defs/CollectionOperation" },
        { "$ref": "#/$defs/NamedOperation" },
        { "$ref": "#/$defs/IdOperation" },
        { "$ref": "#/$defs/TreeOperation" },
        { "$ref": "#/$defs/ContextOperation" },
        { "$ref": "#/$defs/FlowOperation" },
        { "$ref": "#/$defs/PaletteEntriesOperation" }
      ]
    },
    "Query": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "operation"],
      "properties": {
        "kind": { "const": "query" },
        "target": { "$ref": "#/$defs/Target" },
        "operation": { "$ref": "#/$defs/QueryOperation" },
        "where": { "$ref": "#/$defs/Condition" },
        "with": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
        },
        "orderBy": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/OrderBy" }
        },
        "page": { "$ref": "#/$defs/Page" }
      }
    },
    "Point": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "Add": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 3,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "add" },
        "target": { "$ref": "#/$defs/BindingTarget" },
        "to": { "$ref": "#/$defs/Ref" },
        "before": { "$ref": "#/$defs/Ref" },
        "after": { "$ref": "#/$defs/Ref" }
      }
    },
    "Remove": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "remove" },
        "target": { "$ref": "#/$defs/Ref" }
      }
    },
    "Set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "value"],
      "properties": {
        "kind": { "const": "set" },
        "target": { "$ref": "#/$defs/MemberRef" },
        "value": { "$ref": "#/$defs/Expr" }
      }
    },
    "Reset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "reset" },
        "target": { "$ref": "#/$defs/MemberRef" }
      }
    },
    "Move": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 3,
      "maxProperties": 3,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "move" },
        "target": { "$ref": "#/$defs/Ref" },
        "to": {
          "oneOf": [
            { "$ref": "#/$defs/Ref" },
            { "$ref": "#/$defs/Point" }
          ]
        },
        "by": { "$ref": "#/$defs/Point" },
        "before": { "$ref": "#/$defs/Ref" },
        "after": { "$ref": "#/$defs/Ref" }
      }
    },
    "Connect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "from", "to"],
      "properties": {
        "kind": { "const": "connect" },
        "from": { "$ref": "#/$defs/Ref" },
        "to": { "$ref": "#/$defs/Ref" }
      }
    },
    "Disconnect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "from", "to"],
      "properties": {
        "kind": { "const": "disconnect" },
        "from": { "$ref": "#/$defs/Ref" },
        "to": { "$ref": "#/$defs/Ref" }
      }
    },
    "Break": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "const": "break" },
        "target": { "$ref": "#/$defs/Ref" }
      }
    },
    "Insert": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "from", "input", "output", "to"],
      "properties": {
        "kind": { "const": "insert" },
        "from": { "$ref": "#/$defs/Ref" },
        "input": { "$ref": "#/$defs/Ref" },
        "output": { "$ref": "#/$defs/Ref" },
        "to": { "$ref": "#/$defs/Ref" }
      }
    },
    "Wrap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "targets", "with"],
      "properties": {
        "kind": { "const": "wrap" },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Ref" }
        },
        "with": { "$ref": "#/$defs/LocalRef" }
      }
    },
    "Replace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "with"],
      "properties": {
        "kind": { "const": "replace" },
        "target": { "$ref": "#/$defs/Ref" },
        "with": { "$ref": "#/$defs/Ref" }
      }
    },
    "InvokeOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias"],
      "properties": {
        "selector": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*$" },
        "alias": { "type": "string", "pattern": "^(?!(?:true|false|null)$)[A-Za-z_][A-Za-z0-9_]*$" }
      }
    },
    "Invoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "operation", "args", "outputs"],
      "properties": {
        "kind": { "const": "invoke" },
        "target": { "$ref": "#/$defs/Ref" },
        "operation": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
        "args": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
          "additionalProperties": { "$ref": "#/$defs/Expr" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InvokeOutput" }
        }
      }
    },
    "Save": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": { "kind": { "const": "save" } }
    },
    "Compile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": { "kind": { "const": "compile" } }
    },
    "PatchOperation": {
      "oneOf": [
        { "$ref": "#/$defs/Add" },
        { "$ref": "#/$defs/Remove" },
        { "$ref": "#/$defs/Set" },
        { "$ref": "#/$defs/Reset" },
        { "$ref": "#/$defs/Move" },
        { "$ref": "#/$defs/Connect" },
        { "$ref": "#/$defs/Disconnect" },
        { "$ref": "#/$defs/Break" },
        { "$ref": "#/$defs/Insert" },
        { "$ref": "#/$defs/Wrap" },
        { "$ref": "#/$defs/Replace" },
        { "$ref": "#/$defs/Invoke" },
        { "$ref": "#/$defs/Compile" },
        { "$ref": "#/$defs/Save" }
      ]
    },
    "PatchStatement": {
      "oneOf": [
        { "$ref": "#/$defs/Binding" },
        { "$ref": "#/$defs/PatchOperation" }
      ]
    },
    "Patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "dryRun", "statements"],
      "properties": {
        "kind": { "const": "patch" },
        "target": { "$ref": "#/$defs/Target" },
        "dryRun": { "type": "boolean" },
        "statements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/PatchStatement" }
        }
      }
    },
    "SalObject": {
      "oneOf": [
        { "$ref": "#/$defs/Query" },
        { "$ref": "#/$defs/Patch" },
        { "$ref": "#/$defs/ObjectText" }
      ]
    },
    "SourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 },
        "length": { "type": "integer", "minimum": 0 }
      }
    },
    "DiagnosticPath": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "type": "integer", "minimum": 0 }
        ]
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": { "enum": ["error", "warning", "info"] },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/DiagnosticPath" },
        "span": { "$ref": "#/$defs/SourceSpan" },
        "domain": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "expected": true,
        "actual": true,
        "supported": true,
        "matches": { "type": "array", "items": true },
        "suggestion": { "type": "string", "minLength": 1 }
      }
    },
    "ResultPage": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "next": { "type": "string", "minLength": 1 }
      }
    },
    "Result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diagnostics"],
      "properties": {
        "object": { "$ref": "#/$defs/ObjectText" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/Diagnostic" }
        },
        "page": { "$ref": "#/$defs/ResultPage" }
      }
    },
    "MutationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diagnostics", "isError", "dryRun", "valid", "applied", "operation"],
      "allOf": [
        {
          "if": {
            "properties": { "dryRun": { "const": true } },
            "required": ["dryRun"]
          },
          "then": {
            "properties": { "applied": { "const": false } }
          }
        }
      ],
      "properties": {
        "object": { "$ref": "#/$defs/ObjectText" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/Diagnostic" }
        },
        "page": { "$ref": "#/$defs/ResultPage" },
        "isError": { "type": "boolean" },
        "dryRun": { "type": "boolean" },
        "valid": { "type": "boolean" },
        "applied": { "type": "boolean" },
        "assetPath": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "resolvedRefs": true,
        "planned": true,
        "diff": true,
        "previousRevision": { "type": "string", "minLength": 1 },
        "newRevision": { "type": "string", "minLength": 1 }
      }
    },
    "ObjectResult": {
      "oneOf": [
        { "$ref": "#/$defs/Result" },
        { "$ref": "#/$defs/MutationResult" }
      ]
    }
  }
}
