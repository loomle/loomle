{
  "kind": "patch",
  "target": {
    "domain": "blueprint",
    "asset": "/Game/BP_Door",
    "graph": {
      "kind": "name",
      "name": "EventGraph"
    }
  },
  "dryRun": false,
  "bindings": [
    {
      "target": {
        "kind": "local",
        "name": "print"
      },
      "value": {
        "kind": "palette_node",
        "palette": "palette:blueprint:function:/Script/Engine.KismetSystemLibrary.PrintString",
        "defaults": {
          "InString": "Ready"
        }
      }
    }
  ],
  "ops": [
    {
      "kind": "add",
      "binding": "print"
    },
    {
      "kind": "connect",
      "edge": {
        "from": {
          "node": "begin",
          "pin": "Then"
        },
        "to": {
          "node": "print",
          "pin": "Exec"
        }
      }
    },
    {
      "kind": "set",
      "target": {
        "object": "print",
        "field": "InString"
      },
      "value": "Updated"
    },
    {
      "kind": "disconnect",
      "pin": {
        "node": "print",
        "pin": "InString"
      }
    },
    {
      "kind": "remove",
      "node": "print"
    },
    {
      "kind": "move",
      "node": "delay",
      "mode": "by",
      "delta": [120, -40]
    },
    {
      "kind": "reconstruct",
      "node": "delay",
      "preserveLinks": true
    }
  ]
}
