# Query for local context around a branch node.
query EventGraph

find subgraph around branch depth 2

---

graph EventGraph

begin@B001 = EventBeginPlay()
health@B002 = GetVariable(Health)
threshold@B003 = LessEqualFloat(health, 0.0)
branch@B004 = Branch()
dead@B005 = PrintString("Dead")
alive@B006 = PrintString("Alive")

begin -> branch
health.Value -> threshold.A
threshold.ReturnValue -> branch.Condition
branch.True -> dead
branch.False -> alive
