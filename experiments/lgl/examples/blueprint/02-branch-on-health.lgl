# Source pattern: common Blueprint branch/if statement flow.
# Tests exec fanout and a data value feeding Branch.Condition.
graph EventGraph

begin@B001 = EventBeginPlay()
health@B002 = GetVariable(Health)
threshold@B003 = LessEqualFloat(health, 0.0)
branch@B004 = Branch()
dead@B005 = PrintString("Dead")
alive@B006 = PrintString("Alive")

begin -> branch
threshold.ReturnValue -> branch.Condition
branch.True -> dead
branch.False -> alive
