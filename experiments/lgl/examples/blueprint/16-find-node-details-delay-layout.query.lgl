# Query for node and pin layout readback.
query EventGraph

find node details delay with pins, defaults, layout

---

node details EventGraph

delay@A002 = Delay(1.0) at (320, 0) size (200, 100)

pin delay.Exec: exec in <- begin.Then anchor (320, 24)
pin delay.Duration: float in = 1.0 anchor (320, 72)
pin delay.Completed: exec out -> print.Exec anchor (500, 24)
