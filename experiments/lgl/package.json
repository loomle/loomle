{
  "name": "@loomle/lgl-experiment",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Experimental TypeScript SDK scaffold for Loomle Graph Lang.",
  "scripts": {
    "generate:types": "json2ts -i schema/lgl-object.schema.json -o src/generated/lgl-object-schema.ts --cwd . --unreachableDefinitions --unknownAny false",
    "check:generated": "npm run generate:types && git diff --exit-code -- src/generated/lgl-object-schema.ts",
    "build": "tsc -p tsconfig.json",
    "test:schema": "npm run build && node dist/tests/schema/validate-fixtures.js",
    "test:roundtrip": "npm run build && node dist/tests/parser/roundtrip.js",
    "test:examples": "npm run build && node dist/tests/parser/core-examples.js",
    "test:examples:extended": "npm run build && node dist/tests/parser/extended-examples.js",
    "test:examples:reference": "npm run build && node dist/tests/parser/reference-examples.js",
    "test:facade": "npm run build && node dist/tests/sdk/facade.js",
    "test:memory": "npm run build && node dist/tests/sdk/memory-adapter.js",
    "test": "npm run check:generated && npm run test:schema && npm run test:roundtrip && npm run test:examples && npm run test:examples:extended && npm run test:facade && npm run test:memory"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.20.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.6.0"
  }
}
