{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@loomle/sal-experiment": ["../experiments/sal/dist/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
