{
  "name": "@loomle/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone Loomle SAL MCP client.",
  "bin": {
    "loomle": "dist/main.js"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "check:version": "node ../packaging/tools/product-version.mjs check",
    "build:sal": "npm run build --workspace @loomle/sal",
    "build:interfaces": "npm run build --workspace @loomle/interfaces",
    "build": "npm run check:version && npm run clean && npm run build:sal && npm run build:interfaces && tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && node scripts/run-tests.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@loomle/interfaces": "*",
    "@loomle/sal": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
